<?xml version="1.0" encoding="utf-8"?>
<!--
    Backups are disabled entirely (android:allowBackup="false").
    These rules are defense-in-depth for tooling that still reads them:
    conversations, memories, notifications and settings (incl. API keys)
    must never leave the device via backup.
-->
<full-backup-content>
    <exclude domain="sharedpref" path="."/>
    <exclude domain="database" path="."/>
    <exclude domain="file" path="datastore/"/>
</full-backup-content>
